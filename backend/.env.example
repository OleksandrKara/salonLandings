# Square API credentials — never commit real values.
# Get these from the Square Developer Dashboard (https://developer.squareup.com/apps).
SQUARE_ENVIRONMENT=production
SQUARE_ACCESS_TOKEN=
SQUARE_LOCATION_ID=

# App
LOG_LEVEL=INFO
# Comma-separated list of origins allowed to call this API.
CORS_ALLOW_ORIGINS=http://localhost:5173,https://mani.akluxnails.com

# Booking behaviour
AVAILABILITY_SEARCH_DAYS=14
AVAILABILITY_CACHE_SECONDS=30
CATALOG_CACHE_SECONDS=300

# Future integrations (leave blank until wired up)
MAILCHIMP_API_KEY=
MAILCHIMP_AUDIENCE_ID=
