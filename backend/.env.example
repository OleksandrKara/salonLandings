# Square API credentials — never commit real values.
# Get these from the Square Developer Dashboard (https://developer.squareup.com/apps).
SQUARE_ENVIRONMENT=production
SQUARE_ACCESS_TOKEN=
SQUARE_LOCATION_ID=

# App
LOG_LEVEL=INFO
# Comma-separated list of origins allowed to call this API.
CORS_ALLOW_ORIGINS=http://localhost:5173,https://mani.akluxnails.com

# Booking behaviour
AVAILABILITY_SEARCH_DAYS=14
AVAILABILITY_CACHE_SECONDS=30
CATALOG_CACHE_SECONDS=300

# Future integrations (leave blank until wired up)
MAILCHIMP_API_KEY=
MAILCHIMP_AUDIENCE_ID=

# Marketing tracking DB — reuses the shared Postgres container from the
# salonreview project (schema "marketing" within its existing database).
# Host is the container's Docker network alias, not localhost.
MARKETING_DB_HOST=postgres
MARKETING_DB_PORT=5432
MARKETING_DB_NAME=salonreview
MARKETING_DB_USER=salon
MARKETING_DB_PASSWORD=

# salaryReview's internal API (Telegram 4-hand-request relay) — reached over the private Docker
# network already joined for the marketing DB above. Leave blank to silently skip the alert; the
# lead is still captured as a Square contact either way.
INTERNAL_API_BASE_URL=http://backend:8080
INTERNAL_API_KEY=
